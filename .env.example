# ─── Application ──────────────────────────────────────────────────────────────
# Public site URL — used in metadata and sitemap generation.
# NO trailing slash.
NEXT_PUBLIC_SITE_URL=https://chranico.com

# Backend API base URL (server-side only — not NEXT_PUBLIC).
# On the server, Next.js calls this directly. On the client, requests go
# through the /api/site/* rewrite proxy in next.config.mjs.
API_BASE_URL=https://api.chranico.com

# ─── Cache Revalidation ────────────────────────────────────────────────────────
# Secret token used by the backend to trigger ISR cache invalidation via
# POST /api/revalidate or GET /api/revalidate?tag=...
# MUST match the value set on the backend CMS / admin panel.
# Generate a secure value: openssl rand -hex 32
NEXT_REVALIDATE_SECRET=chranico_super_secure_revalidate_2026

# ─── Node / Next.js ────────────────────────────────────────────────────────────
NODE_ENV=production
